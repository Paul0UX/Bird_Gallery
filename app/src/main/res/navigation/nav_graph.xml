<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/FirstFragment">

    <fragment
        android:id="@+id/FirstFragment"
        android:name="com.example.wiki_bids.FirstFragment"
        android:label="@string/first_fragment_label"
        tools:layout="@layout/fragment_first">

        <action
            android:id="@+id/action_FirstFragment_to_SecondFragment"
            app:destination="@id/SecondFragment" />
        <action
            android:id="@+id/action_FirstFragment_to_ViewBirdFragment"
            app:destination="@id/ViewBirdFragment" />
    </fragment>
    <fragment
        android:id="@+id/ViewBirdFragment"
        android:name="com.example.wiki_bids.ViewBirdFragment"
        android:label="Visualizar Ave"
        tools:layout="@layout/fragment_view_bird" />
    <fragment
        android:id="@+id/SecondFragment"
        android:name="com.example.wiki_bids.SecondFragment"
        android:label="@string/second_fragment_label"
        tools:layout="@layout/fragment_second">

        <action
            android:id="@+id/action_SecondFragment_to_FirstFragment"
            app:destination="@id/FirstFragment" />
    </fragment>
</navigation>